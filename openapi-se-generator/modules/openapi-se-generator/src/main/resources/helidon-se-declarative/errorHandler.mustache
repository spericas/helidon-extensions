package {{package}};

import io.helidon.service.registry.Service;
import io.helidon.webserver.http.ErrorHandler;
{{#operations}}
import {{package}}.{{classname}}Exception;
{{/operations}}

/**
 * Registers an error handler for {@link {{classname}}Exception} with the Helidon WebServer.
 *
 * <p>Discovered automatically via the service registry ({@code @Service.Singleton}).
 * Serialises the error as JSON using the spec's error schema and sets the HTTP status.</p>
 */
{{#operations}}
@Service.Singleton
public class {{classname}}ErrorHandler implements ErrorHandler<{{classname}}Exception> {

    @Override
    public void handle(io.helidon.webserver.http.ServerRequest req,
                       io.helidon.webserver.http.ServerResponse res,
                       {{classname}}Exception ex) {
        // Build JSON manually — Helidon build-time binding only serialises @Json.Entity classes,
        // not java.util.Map. Replace with res.send(new {{errorModel}}(...)) once the error
        // model class has the right constructor.
        String message = ex.getMessage() == null ? ""
                : ex.getMessage().replace("\\", "\\\\").replace("\"", "\\\"");
        String json = "{\"code\":" + ex.status().code()
                + ",\"message\":\"" + message + "\"}";
        res.status(ex.status());
        res.headers().contentType(io.helidon.common.media.type.MediaTypes.APPLICATION_JSON);
        res.send(json);
    }
}
{{/operations}}
