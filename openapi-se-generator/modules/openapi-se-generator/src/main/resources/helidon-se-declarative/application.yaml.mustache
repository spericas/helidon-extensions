server:
  port: 8080
  host: 0.0.0.0
  # Uncomment to include request-scoped error details in responses (NOT for production):
  # error-handling:
  #   include-entity: true

{{#generateClient}}
app:
  client:
    endpoint: "http://localhost:8080"
{{/generateClient}}

{{#serverOpenApi}}
# OpenAPI endpoint is auto-discovered from META-INF/openapi.yaml on the classpath.
# Access at: GET /openapi
{{/serverOpenApi}}

{{#hasSecurity}}
# ---
# Security configuration — required: one or more operations use @RoleValidator.Roles.
# Configure an authentication provider and the ABAC role provider below.
# The ABAC provider (helidon-security-providers-abac) is already on the classpath.
#
# Example using HTTP Basic Auth (replace with your production provider):
#
# security:
#   providers:
#     - abac:
#     - http-basic-auth:
#         users:
#           - login: "alice"
#             password: "secret"
#             roles: ["admin", "user"]
#
# Example using JWT / OIDC:
#
# security:
#   providers:
#     - abac:
#     - jwt:
#         atn-token:
#           jwk-resource:
#             resource-path: "public-jwk.json"
{{/hasSecurity}}
{{^hasSecurity}}
